generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuario {
  id  Int   @id @default(autoincrement())
  nombre    String
  email     String @unique
  password  String
  createdAt DateTime @default(now())
}